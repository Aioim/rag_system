# ============================================================================
# RAG 企业级知识库问答系统 — 环境变量配置模板
# ============================================================================
# 使用方式:
#   1. cp .env.example .env
#   2. 用加密工具生成密钥值:  python -m security.env_encrypt
#      或直接加密:            python -m security.env_encrypt LLM_API_KEY
#   3. 将生成的 ENC[...] 值填入下方对应变量
#   4. 确保 .env 在 .gitignore 中（默认已配置）
#
# ⚠️  安全约定:
#   - 密钥、密码、Token 等敏感信息 只允许 通过此 .env 文件配置
#   - 禁止写入 YAML 文件（defaults.yaml / prod.yaml 等）
#   - 支持 Fernet 加密格式: KEY=ENC[base64_ciphertext]
#   - 启动时调用 load_secure_dotenv() 自动解密
#
# 优先级: CLI 覆盖 > 环境变量 > {env}.yaml > defaults.yaml > 代码默认值
# 双下划线 __ 表示嵌套: RETRIEVAL__TOP_K=10 → retrieval.top_k = 10
# 键名不区分大小写
# ============================================================================

# ============================================================================
# 运行环境
# ============================================================================

ENV=dev
DEBUG=false

# ============================================================================
# LLM API 密钥（必填）
# ============================================================================

# Claude API 密钥 — 对应配置 llm.api_key
# 获取: https://console.anthropic.com/
# 加密: python -m security.env_encrypt LLM_API_KEY
LLM_API_KEY=ENC[replace-with-encrypted-value]

# ============================================================================
# HuggingFace 模型下载（必填）
# ============================================================================

# HuggingFace Token — 用于下载 BGE Embedding / Reranker 等受限模型
# 获取: https://huggingface.co/settings/tokens
# 加密: python -m security.env_encrypt HUGGINGFACE_TOKEN
HUGGINGFACE_TOKEN=ENC[replace-with-encrypted-value]

# HuggingFace 镜像端点（国内用户建议设置）
# HUGGINGFACE_ENDPOINT=https://hf-mirror.com

# ============================================================================
# API 服务（可选）
# ============================================================================

# API__HOST=0.0.0.0
# API__PORT=8000
# API__WORKERS=1

# ============================================================================
# 检索参数（可选）
# ============================================================================

# RETRIEVAL__TOP_K=5
# RETRIEVAL__RRF_K=60
# RETRIEVAL__MMR_LAMBDA=0.7
# RETRIEVAL__RELEVANCE_THRESHOLD_SUFFICIENT=0.5
# RETRIEVAL__RELEVANCE_THRESHOLD_NEED_MORE=0.3
# RETRIEVAL__MAX_CONTEXT_TOKENS=6000

# ============================================================================
# 文档分块（可选）
# ============================================================================

# CHUNKING__CHUNK_SIZE=512
# CHUNKING__OVERLAP=64
# CHUNKING__STRATEGY=semantic

# ============================================================================
# Embedding 模型（可选）
# ============================================================================

# EMBEDDING__MODEL=BAAI/bge-large-zh-v1.5
# EMBEDDING__DEVICE=cpu
# EMBEDDING__BATCH_SIZE=32

# ============================================================================
# LLM 路由（可选）
# ============================================================================

# LLM__DEFAULT=claude-sonnet-5
# LLM__LIGHTWEIGHT=claude-haiku-4-5
# LLM__API_BASE_URL=https://api.anthropic.com

# ============================================================================
# 会话管理（可选）
# ============================================================================

# SESSION__TTL_HOURS=2
# SESSION__MAX_HISTORY_ROUNDS=10

# ============================================================================
# 向量数据库 FAISS / Milvus（可选）
# ============================================================================

# FAISS__INDEX_TYPE=IVF_FLAT
# FAISS__NLIST=100
# FAISS__NPROBE=10

# MILVUS__HOST=localhost
# MILVUS__PORT=19530

# ============================================================================
# 联网搜索兜底（可选）
# ============================================================================

# WEB_SEARCH__ENABLED=true
# WEB_SEARCH__PROVIDER=duckduckgo
# WEB_SEARCH__TIMEOUT_SECONDS=10

# ============================================================================
# 日志（可选）
# ============================================================================

# LOG__LOG_LEVEL=INFO
# LOG__LOG_FILE=rag_service.log
